#!/usr/bin/env bash
set -euo pipefail

script_dir="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd -P)"
repo_root="$(cd "$script_dir/../.." && pwd -P)"

export AGENT_ORCHESTRA_REPO_ROOT="${AGENT_ORCHESTRA_REPO_ROOT:-$repo_root}"
exec "${AGENT_ORCHESTRA_PYTHON:-python3}" "$repo_root/.codex/agent_orchestra_minimal/cli.py" start "$@"
